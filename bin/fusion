#!/usr/bin/env bash
# Standalone MindBridge Fusion launcher. This does not start Docker/FusionDocker.

SCRIPT="$(readlink -f "$0" 2>/dev/null || echo "$0")"
if [ -f "/.dockerenv" ] || grep -q 'docker\|lxc' /proc/1/cgroup 2>/dev/null; then
    ROOT_DIR="/workspace"
else
    ROOT_DIR="$(cd "$(dirname "$SCRIPT")/.." && pwd)"
fi

case "${1:-}" in
    ""|--sam3)
        shift 2>/dev/null || true
        bash "$ROOT_DIR/scripts/start_service.sh" realsense
        bash "$ROOT_DIR/scripts/start_service.sh" fastfoundation
        bash "$ROOT_DIR/scripts/start_service.sh" sam3
        bash "$ROOT_DIR/scripts/start_service.sh" flowpose
        bash "$ROOT_DIR/scripts/start_service.sh" siglip
        exec python -m mindbridge.src.fusion run --detector sam3 --pipeline full "$@"
         ;;

    --yolo)
        shift
        bash "$ROOT_DIR/scripts/start_service.sh" realsense
        bash "$ROOT_DIR/scripts/start_service.sh" fastfoundation
        bash "$ROOT_DIR/scripts/start_service.sh" yolo
        bash "$ROOT_DIR/scripts/start_service.sh" flowpose
        bash "$ROOT_DIR/scripts/start_service.sh" siglip
        exec python -m mindbridge.src.fusion run --detector yolo --pipeline full "$@"
        ;;

    --usb-sam3)
        shift
        bash "$ROOT_DIR/scripts/start_service.sh" sam3
        bash "$ROOT_DIR/scripts/start_service.sh" siglip
        exec python -m mindbridge.src.fusion run --detector sam3 --pipeline basic --rgb-source usb "$@"
        ;;

    --usb-yolo)
        shift
        bash "$ROOT_DIR/scripts/start_service.sh" yolo
        bash "$ROOT_DIR/scripts/start_service.sh" siglip
        exec python -m mindbridge.src.fusion run --detector yolo --pipeline basic --rgb-source usb "$@"
        ;;

    --ui-only)
        shift
        exec python -m mindbridge.src.fusion serve-ui "$@"
        ;;

    help|--help|-h)
        echo "Usage: fusion [OPTION]"
        echo ""
        echo "Standalone Fusion，不启动 Docker/FusionDocker:"
        echo "  (无参数)/--sam3   RealSense + FastFoundation + SAM3 + FlowPose + SigLIP + Fusion UI/ZMQ"
        echo "  --yolo            RealSense + FastFoundation + YOLO + FlowPose + SigLIP + Fusion UI/ZMQ"
        echo "  --usb-sam3        USB RGB + SAM3 + SigLIP + Fusion UI/ZMQ"
        echo "  --usb-yolo        USB RGB + YOLO + SigLIP + Fusion UI/ZMQ"
        echo "  --ui-only         只启动 Fusion UI/ZMQ listener"
        echo ""
        echo "常用附加参数:"
        echo "  --ui-port 8765"
        echo "  --camera-index 1"
        echo "  --sam3-prompts \"green small box\""
        echo "  --show"
        exit 0
        ;;
esac
